{
  "name": "deze-backend",
  "version": "0.1.0",
  "private": true,
  "description": "DEZE (Detail Central) - detailing marketplace API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "db:generate": "prisma generate --schema=../database/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../database/schema.prisma",
    "db:seed": "node ../database/seed.js",
    "db:reset": "prisma migrate reset --schema=../database/schema.prisma --skip-seed && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "nodemailer": "^6.9.13",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.15.0"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true
  }
}
