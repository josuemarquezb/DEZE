{
  "name": "deze-backend",
  "version": "0.1.0",
  "private": true,
  "description": "DEZE (Detail Central) - detailing marketplace API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "prisma:generate": "prisma generate --schema=../database/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../database/schema.prisma",
    "seed": "node ../database/seed.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "dotenv": "^16.4.5",
    "@prisma/client": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "stripe": "^16.0.0",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "prisma": "^5.15.0",
    "nodemon": "^3.1.4"
  }
}
