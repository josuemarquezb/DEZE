# Copy to backend/.env and fill in real values. Never commit the real .env file.

# --- Server ---
NODE_ENV=development
PORT=5000

# --- Database (PostgreSQL, used by Prisma) ---
DATABASE_URL=postgresql://user:password@localhost:5432/deze

# --- Auth ---
# Generate your own with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=b025abe7afc7283569b9bf6b2ca1452a5376be9170ce35bc715524be7549ac3b

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Mapbox ---
MAPBOX_TOKEN=pk.xxx

# --- Email (nodemailer) ---
# Either SENDGRID_API_KEY, or EMAIL_HOST/PORT/USER/PASS (e.g. Gmail SMTP).
# Neither set → emails are logged instead of sent (see utils/mailer.js).
SENDGRID_API_KEY=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="DEZE <noreply@deze.com>"

# Low-priority admin email (e.g. "new detailer signed up") — leave blank to skip.
ADMIN_NOTIFICATION_EMAIL=

# Used to build links inside emails (job detail, onboarding, etc.).
FRONTEND_URL=http://localhost:3000

# Note: the frontend needs its own env file (frontend/.env, VITE_-prefixed
# variables) since Vite only exposes VITE_* keys to client-side code.
# See frontend/.env.example.
#
# Note: database/ also needs its own .env (just DATABASE_URL) so `prisma`
# CLI commands work when run directly from that folder. See database/.env.example.
